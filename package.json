{
  "name": "@you-died/root",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:client": "pnpm --filter @you-died/client dev",
    "dev:server": "pnpm --filter @you-died/server dev",
    "build": "pnpm -r --if-present run build",
    "typecheck": "pnpm -r --if-present run typecheck",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "knip": "knip",
    "test": "pnpm -r --if-present run test",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "stylelint": "pnpm --filter @you-died/client stylelint"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher",
      "msgpackr-extract"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "knip": "^6.4.1",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.2"
  }
}
